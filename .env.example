# Copy this file to .env and fill in real values. NEVER commit .env.

# FRED API key — free at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=<fred_api_key_here>

# Optional: path to a file containing the FRED key (single line) instead of FRED_API_KEY
# FRED_API_KEY_FILE=<path_to_key_file>

# Interactive Brokers (paper trading)
IBKR_ACCOUNT=<ibkr_account_here>
# IBKR_HOST=127.0.0.1
# IBKR_PORT=4002
# IBKR_CLIENT_ID=1

# Optional: override pipeline ticker universe (comma-separated)
# PIPELINE_TICKERS=SPY,GLD,...

# Optional: set to 1 to bypass market-data cache during development
# DISABLE_MARKET_CACHE=0
